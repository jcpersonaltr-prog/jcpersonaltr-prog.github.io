---
import glob from '../data/global.json';
const { pathname } = Astro.url;
const links = [
  { num: '01', label: 'Relatório', href: '/relatorio/' },
  { num: '02', label: 'Treino', href: '/treino/' },
  { num: '03', label: 'Media', href: '/media/' },
  { num: '04', label: 'Tinta', href: '/tinta/' },
  { num: '05', label: 'Comunidade', href: '/comunidade/' },
];
const isActive = (href: string) => pathname.startsWith(href);
---

<header class="masthead">
  <div class="wrap">
    <a href="/" class="logo" aria-label="The Plasmik Report — página inicial">
      THE PLASMIK REPORT<span class="dot">.</span>
    </a>
    <nav aria-label="Navegação principal">
      {links.map((l) => (
        <a href={l.href} class:list={['navlink', { active: isActive(l.href) }]} aria-current={isActive(l.href) ? 'page' : undefined}>
          <span class="num">{l.num}</span> {l.label}
        </a>
      ))}
      <a href="/sobre/" class:list={['navlink', { active: isActive('/sobre/') }]}>Sobre</a>
      <a href={glob.lojaUrl} class="navlink loja" target="_blank" rel="noopener">Loja</a>
    </nav>
  </div>
</header>

<style>
  .masthead {
    border-bottom: 1px solid var(--line);
    padding: 22px 0 16px;
  }
  .logo {
    font-family: var(--font-display);
    font-size: clamp(20px, 4vw, 28px);
    letter-spacing: 2px;
    color: var(--paper);
    border-bottom: none;
    display: inline-block;
  }
  .logo:hover { color: var(--paper); }
  .dot { color: var(--amber); }
  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 18px;
    margin-top: 14px;
  }
  .navlink {
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
  }
  .navlink .num {
    font-family: var(--font-display);
    color: var(--faint);
    margin-right: 2px;
  }
  .navlink:hover, .navlink:focus-visible {
    color: var(--amber);
    border-bottom-color: var(--amber);
  }
  .navlink.active { color: var(--amber); }
  .navlink.active .num { color: var(--amber); }
  .loja {
    border: 1px solid #444;
    padding: 3px 12px;
    color: var(--paper);
  }
  .loja:hover { border-color: var(--amber); }
</style>
