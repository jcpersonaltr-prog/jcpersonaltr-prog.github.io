---
import glob from '../data/global.json';
const year = new Date().getFullYear();
---

<footer>
  <div class="wrap subscribe">
    <p class="display cta-text">{glob.subscricaoFrase}</p>
    <!--
      LIGAÇÃO DA NEWSLETTER:
      Cria conta gratuita em https://buttondown.com e substitui
      "theplasmikreport" pelo teu username no action abaixo.
      Alternativa (se publicares no Netlify): remove o action e
      adiciona o atributo data-netlify="true" ao form.
    -->
    <form
      action={`https://buttondown.com/api/emails/embed-subscribe/${glob.buttondownUsername}`}
      method="post"
      target="_blank"
    >
      <label class="sr-only" for="email">O teu email</label>
      <input id="email" type="email" name="email" required placeholder="o-teu-email@exemplo.pt" />
      <button type="submit" class="btn btn--amber">Subscrever</button>
    </form>
  </div>
  <div class="wrap bottom">
    <p class="brand">THE PLASMIK REPORT<span style="color: var(--amber)">.</span> <span class="tag">{glob.tagline}</span></p>
    <nav aria-label="Redes sociais">
      {glob.sociais.map((s) => (
        <a href={s.url} target="_blank" rel="noopener">{s.rotulo}</a>
      ))}
    </nav>
    <p class="copy">© {year} João Carvalho · Método Perfektus. Todos os direitos reservados.</p>
  </div>
</footer>

<style>
  footer { border-top: 1px solid var(--line); }
  .subscribe {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    padding-top: 32px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--line);
  }
  .cta-text { flex: 1; min-width: 240px; font-size: 17px; margin: 0; }
  form { display: flex; gap: 8px; flex-wrap: wrap; }
  input[type='email'] {
    background: transparent;
    border: 1px solid #444;
    color: var(--paper);
    font-family: var(--font-body);
    font-size: 14px;
    padding: 11px 16px;
    min-width: 230px;
  }
  input[type='email']::placeholder { color: var(--faint); }
  input[type='email']:focus { outline: 2px solid var(--amber); outline-offset: 2px; }
  .bottom { padding-top: 24px; padding-bottom: 32px; }
  .brand {
    font-family: var(--font-display);
    font-size: 14px;
    letter-spacing: 1.5px;
    margin: 0 0 10px;
  }
  .tag {
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 1px;
    color: var(--faint);
    text-transform: uppercase;
    margin-left: 8px;
  }
  .bottom nav { display: flex; gap: 18px; margin-bottom: 14px; }
  .bottom nav a { font-size: 13px; letter-spacing: 1px; text-transform: uppercase; }
  .copy { font-size: 12px; color: var(--faint); margin: 0; }
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }
</style>
