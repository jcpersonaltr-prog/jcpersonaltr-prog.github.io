---
import Base from '../../layouts/Base.astro';
import dados from '../../data/videos.json';
const videos = dados.videos;

const lista = videos.filter((v) => v.ytId !== 'SUBSTITUI_PELO_ID');
const tipos = ['Todos', 'Podcast', 'Clip'];
---

<Base title="Vídeos" description="Podcasts completos e clips do The Plasmik Report — conversas longas, sem cortes, e os momentos essenciais.">
  <section class="section grain">
    <div class="wrap">
      <p class="stamp">03 — Media / Vídeos</p>
      <h1>Ver e ouvir.</h1>
      <p class="lead">Podcasts completos e clips parciais. Clica na miniatura para reproduzir aqui mesmo.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="filter-row" role="group" aria-label="Filtrar vídeos">
        {tipos.map((t, i) => (
          <button class:list={['pillbtn', { on: i === 0 }]} data-value={t}>{t === 'Todos' ? 'Todos' : t + 's'}</button>
        ))}
      </div>

      {lista.length === 0 && (
        <p class="vazio">Ainda sem vídeos. Adiciona-os em <code>src/data/videos.json</code> — instruções no FASE3-LEIA-ME.md.</p>
      )}

      <div class="grid">
        {lista.map((v) => (
          <figure class="video card" data-tipo={v.tipo}>
            <button class="thumb" data-yt={v.ytId} aria-label={`Reproduzir: ${v.titulo}`}>
              <img src={`https://i.ytimg.com/vi/${v.ytId}/hqdefault.jpg`} alt="" loading="lazy" class="bw" />
              <span class="play" aria-hidden="true">►</span>
            </button>
            <figcaption>
              <span class="pill pill--amber">{v.tipo}</span>
              <h3>{v.titulo}</h3>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
</Base>

<script>
  // Filtro por tipo
  const botoes = document.querySelectorAll('.pillbtn');
  const cartoes = document.querySelectorAll('.video');
  botoes.forEach((b) => {
    b.addEventListener('click', () => {
      botoes.forEach((x) => x.classList.toggle('on', x === b));
      const v = b.dataset.value;
      cartoes.forEach((c) => {
        c.style.display = v === 'Todos' || c.dataset.tipo === v ? '' : 'none';
      });
    });
  });

  // Carregar o iframe do YouTube só quando o utilizador clica (mais rápido e mais privado)
  document.querySelectorAll('.thumb').forEach((t) => {
    t.addEventListener('click', () => {
      const id = t.dataset.yt;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1`;
      iframe.title = 'Vídeo do YouTube';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      t.replaceWith(iframe);
    });
  });
</script>

<style>
  .lead { color: var(--muted); max-width: 540px; margin-top: 14px; }
  .filter-row { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 22px; }
  .pillbtn {
    background: transparent;
    border: 1px solid var(--line-strong);
    color: var(--muted);
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 1px;
    padding: 5px 14px;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .pillbtn:hover { border-color: var(--amber); color: var(--paper); }
  .pillbtn.on { border-color: var(--amber); color: var(--amber); }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; }
  .video { margin: 0; padding: 0; overflow: hidden; }
  .thumb {
    position: relative;
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: #000;
    cursor: pointer;
    aspect-ratio: 16 / 9;
  }
  .thumb img { width: 100%; height: 100%; object-fit: cover; opacity: 0.85; transition: opacity 0.15s ease; }
  .thumb:hover img { opacity: 1; }
  .play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-size: 20px;
    color: var(--amber-ink);
  }
  .play::before {
    content: '';
    position: absolute;
    width: 58px;
    height: 58px;
    background: var(--amber);
    z-index: -1;
  }
  .video :global(iframe) { width: 100%; aspect-ratio: 16 / 9; border: none; display: block; }
  figcaption { padding: 14px 16px 16px; }
  .pill {
    display: inline-block;
    border: 1px solid var(--amber);
    color: var(--amber);
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 2px 10px;
    margin-bottom: 8px;
  }
  figcaption h3 { font-size: 16px; }
  .vazio { color: var(--faint); font-size: 14px; }
</style>
