---
import Base from '../../layouts/Base.astro';
import textos from '../../data/textos.json';
import dados from '../../data/galeria.json';
const t = textos.galeria;

// A galeria é gerida no painel /admin (Treino & Media → Galeria).
// Cada item tem uma imagem e um grupo: "Fotos" (tratamento P&B) ou "Prop Art" (cores originais).
const grupos = [
  { nome: 'Fotos', imagens: dados.itens.filter((i) => i.grupo === 'Fotos') },
  { nome: 'Prop Art', imagens: dados.itens.filter((i) => i.grupo === 'Prop Art') },
];
---

<Base title="Galeria" description="O arquivo visual do The Plasmik Report: fotografia a preto e branco e Prop Art.">
  <section class="section grain">
    <div class="wrap">
      <p class="stamp">03 — Media / Galeria</p>
      <h1>{t.titulo}</h1>
      <p class="lead">{t.lead}</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="filter-row" role="group" aria-label="Escolher galeria">
        {grupos.map((g, i) => (
          <button class:list={['pillbtn', { on: i === 0 }]} data-value={g.nome}>{g.nome}</button>
        ))}
      </div>

      {grupos.map((g, gi) => (
        <div class="galeria" data-grupo={g.nome} style={gi === 0 ? '' : 'display:none'}>
          {g.imagens.length === 0 && (
            <p class="vazio">Sem imagens ainda — adiciona-as no painel /admin, em Treino & Media → Galeria.</p>
          )}
          <div class="grid">
            {g.imagens.map((item) => (
              <button class="celula" data-src={encodeURI(item.imagem)}>
                <img src={encodeURI(item.imagem)} alt={item.legenda ?? ''} loading="lazy" class:list={[{ bw: g.nome === 'Fotos' }]} />
              </button>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <dialog id="lightbox">
    <button id="fechar" aria-label="Fechar">×</button>
    <img id="grande" src="" alt="Imagem ampliada" />
  </dialog>
</Base>

<script>
  const botoes = document.querySelectorAll('.pillbtn');
  const galerias = document.querySelectorAll('.galeria');
  botoes.forEach((b) => {
    b.addEventListener('click', () => {
      botoes.forEach((x) => x.classList.toggle('on', x === b));
      galerias.forEach((g) => {
        g.style.display = g.dataset.grupo === b.dataset.value ? '' : 'none';
      });
    });
  });

  const lb = document.getElementById('lightbox');
  const grande = document.getElementById('grande');
  document.querySelectorAll('.celula').forEach((c) => {
    c.addEventListener('click', () => {
      grande.src = c.dataset.src;
      lb.showModal();
    });
  });
  document.getElementById('fechar').addEventListener('click', () => lb.close());
  lb.addEventListener('click', (e) => { if (e.target === lb) lb.close(); });
</script>

<style>
  .lead { color: var(--muted); max-width: 540px; margin-top: 14px; }
  .filter-row { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 22px; }
  .pillbtn {
    background: transparent;
    border: 1px solid var(--line-strong);
    color: var(--muted);
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 1px;
    padding: 5px 14px;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .pillbtn:hover { border-color: var(--amber); color: var(--paper); }
  .pillbtn.on { border-color: var(--amber); color: var(--amber); }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; }
  .celula {
    padding: 0;
    border: 1px solid var(--line-strong);
    background: var(--panel);
    cursor: zoom-in;
    aspect-ratio: 1;
    overflow: hidden;
    transition: border-color 0.15s ease;
  }
  .celula:hover { border-color: var(--amber); }
  .celula img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .vazio { color: var(--faint); font-size: 14px; }
  dialog {
    background: var(--ink);
    border: 1px solid var(--line-strong);
    padding: 12px;
    max-width: min(92vw, 1000px);
  }
  dialog::backdrop { background: rgba(0, 0, 0, 0.85); }
  dialog img { max-width: 100%; max-height: 82vh; display: block; }
  #fechar {
    position: absolute;
    top: 6px;
    right: 10px;
    background: none;
    border: none;
    color: var(--amber);
    font-size: 26px;
    cursor: pointer;
    line-height: 1;
  }
</style>
