---
import Base from '../layouts/Base.astro';
import dados from '../data/loja.json';

// Loja gerida no painel /admin (Páginas → Loja).
// Cada item: tag, título, descrição, preço, imagem opcional, botão com link.
---

<Base title="Loja" description="Packs, programas e material do Método Perfektus — a loja do The Plasmik Report.">
  <section class="section grain">
    <div class="wrap">
      <p class="stamp">Loja</p>
      <h1>{dados.titulo}</h1>
      <p class="lead">{dados.lead}</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      {dados.itens.length === 0 && (
        <p class="vazio">Sem ofertas de momento. Adiciona-as no painel /admin, em Páginas → Loja.</p>
      )}
      <div class="grid">
        {dados.itens.map((item) => (
          <article class:list={['card', 'oferta', { destaque: item.destaque }]}>
            {item.imagem && (
              <div class="foto">
                <img src={encodeURI(item.imagem)} alt={item.titulo} loading="lazy" />
              </div>
            )}
            <div class="corpo">
              {item.tag && <span class="pill">{item.tag}</span>}
              <h3>{item.titulo}</h3>
              <p class="desc">{item.descricao}</p>
              <div class="rodape">
                {item.preco && <span class="preco">{item.preco}</span>}
                <a class="btn btn--amber" href={item.botaoLink} target={item.botaoLink?.startsWith('http') ? '_blank' : undefined} rel="noopener">{item.botaoRotulo}</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .lead { color: var(--muted); max-width: 540px; margin-top: 14px; }
  .vazio { color: var(--faint); font-size: 14px; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }
  .oferta { padding: 0; overflow: hidden; display: flex; flex-direction: column; }
  .oferta.destaque { border-color: var(--amber); }
  .foto { aspect-ratio: 4 / 3; background: #000; }
  .foto img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .corpo { padding: 20px 22px 22px; display: flex; flex-direction: column; flex: 1; }
  .pill {
    align-self: flex-start;
    border: 1px solid var(--amber);
    color: var(--amber);
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 2px 10px;
    margin-bottom: 10px;
  }
  .oferta h3 { margin-bottom: 8px; }
  .desc { font-size: 14px; color: var(--muted); margin: 0 0 18px; flex: 1; }
  .rodape {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }
  .preco {
    font-family: var(--font-display);
    font-size: 24px;
    color: var(--amber);
  }
</style>
