---
import Base from '../../layouts/Base.astro';
import textos from '../../data/textos.json';
import { getCollection } from 'astro:content';
const t = textos.relatorio;

const edicoes = (await getCollection('relatorio')).sort((a, b) => b.data.numero - a.data.numero);
const fmt = (d: Date) =>
  d.toLocaleDateString('pt-PT', { day: '2-digit', month: 'short', year: 'numeric' }).replace('.', '');
---

<Base title="Relatório" description="O arquivo completo do The Plasmik Report: todas as newsletters, artigos e Truth Uncovered.">
  <section class="section grain">
    <div class="wrap">
      <p class="stamp">01 — Relatório</p>
      <h1>{t.titulo}</h1>
      <p class="lead">{t.lead}</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap list">
      {edicoes.map((e) => (
        <a class="card entry" href={`/relatorio/${e.id}/`}>
          <span class="edno">Nº {String(e.data.numero).padStart(2, '0')}</span>
          <span class="body">
            <h3>{e.data.titulo}</h3>
            <p>{e.data.resumo}</p>
            <span class="meta">
              {fmt(e.data.data)}
              {e.data.tags.map((t) => <span class="pill">{t}</span>)}
            </span>
          </span>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  .lead { color: var(--muted); max-width: 520px; margin-top: 14px; }
  .list { display: grid; gap: 14px; }
  .entry { display: flex; gap: 20px; align-items: flex-start; }
  .edno {
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--amber);
    min-width: 64px;
    flex-shrink: 0;
  }
  .body { flex: 1; }
  .entry h3 { margin-bottom: 6px; }
  .entry p { font-size: 14px; color: var(--muted); margin: 0 0 10px; }
  .meta {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--faint);
  }
  .pill {
    border: 1px solid var(--line-strong);
    padding: 2px 10px;
    font-size: 11px;
  }
  @media (max-width: 560px) {
    .entry { flex-direction: column; gap: 8px; }
  }
</style>
