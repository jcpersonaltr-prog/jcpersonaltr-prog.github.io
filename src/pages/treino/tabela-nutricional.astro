---
import Base from '../../layouts/Base.astro';
import textos from '../../data/textos.json';
const t = textos.tabela;
---

<Base title="Tabela Nutricional" description="Base de dados nutricional pesquisável do The Plasmik Report — valores por 100 g, com cálculo rápido de refeições.">
  <section class="section grain">
    <div class="wrap">
      <p class="stamp">02 — Treino / Tabela Nutricional</p>
      <h1>{t.titulo}</h1>
      <p class="lead">{t.lead} Usa o botão <strong>+</strong> para montares uma refeição e veres os totais.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="refeicao" id="refeicao">
        <p class="stamp stamp--faint">Cálculo rápido — a tua refeição</p>
        <p class="vazia" id="refVazia">Ainda sem alimentos. Pesquisa na tabela abaixo e adiciona com o botão <span class="mais-ex">+</span>.</p>
        <div class="ref-lista" id="refLista"></div>
        <div class="ref-totais" id="refTotais" hidden></div>
        <button class="btn btn--ghost limpar" id="refLimpar" hidden>Limpar refeição</button>
      </div>

      <div class="toolbar">
        <label class="sr-only" for="q">Pesquisar alimento</label>
        <input id="q" type="search" placeholder="Pesquisar alimento…" autocomplete="off" />
        <a class="btn btn--ghost" href="/data/alimentos.csv" download>Descarregar CSV</a>
      </div>
      <p class="count" id="count" aria-live="polite"></p>
      <div class="table-wrap">
        <table id="tabela">
          <thead><tr id="cabecalho"></tr></thead>
          <tbody id="corpo"></tbody>
        </table>
      </div>
      <p class="nota" id="erro" hidden>Não foi possível carregar a tabela. Confirma que o ficheiro <code>public/data/alimentos.csv</code> existe.</p>
    </div>
  </section>
</Base>

<script>
  // Tabela pesquisável + calculadora de refeição.
  // Lê /data/alimentos.csv (deteta ; ou ,). A 1.ª coluna é o nome;
  // as restantes assumem-se numéricas por 100 g para os totais.
  const cab = document.getElementById('cabecalho');
  const corpo = document.getElementById('corpo');
  const q = document.getElementById('q');
  const count = document.getElementById('count');
  const refVazia = document.getElementById('refVazia');
  const refLista = document.getElementById('refLista');
  const refTotais = document.getElementById('refTotais');
  const refLimpar = document.getElementById('refLimpar');

  let linhas = [], colunas = [], ordem = { col: -1, asc: true };
  let refeicao = []; // [{ id, gramas }]

  function parseCSV(texto) {
    const brutas = texto.trim().split(/\r?\n/).filter((l) => l.trim() !== '');
    const sep = (brutas[0].match(/;/g) || []).length >= (brutas[0].match(/,/g) || []).length ? ';' : ',';
    colunas = brutas[0].split(sep).map((c) => c.trim());
    linhas = brutas.slice(1).map((l, i) => ({ id: i, v: l.split(sep).map((c) => c.trim()) }));
  }

  function numero(v) {
    const n = parseFloat(String(v).replace(',', '.'));
    return isNaN(n) ? 0 : n;
  }

  function fmt(n) {
    return (Math.round(n * 10) / 10).toLocaleString('pt-PT');
  }

  /* ---------- Tabela ---------- */

  function render() {
    const termo = q.value.trim().toLowerCase();
    let visiveis = linhas.filter((l) => !termo || l.v[0].toLowerCase().includes(termo));

    if (ordem.col >= 0) {
      visiveis = [...visiveis].sort((a, b) => {
        const va = a.v[ordem.col], vb = b.v[ordem.col];
        const na = parseFloat(String(va).replace(',', '.'));
        const nb = parseFloat(String(vb).replace(',', '.'));
        let r;
        if (!isNaN(na) && !isNaN(nb)) r = na - nb;
        else r = String(va).localeCompare(String(vb), 'pt');
        return ordem.asc ? r : -r;
      });
    }

    corpo.innerHTML = visiveis
      .map((l) =>
        `<tr>${l.v.map((c, i) => `<td class="${i === 0 ? 'nome' : 'num'}">${c}</td>`).join('')}<td class="acao"><button class="mais" data-id="${l.id}" aria-label="Adicionar ${l.v[0]} à refeição">+</button></td></tr>`
      )
      .join('');
    count.textContent = visiveis.length === 1 ? '1 alimento' : `${visiveis.length} alimentos`;

    corpo.querySelectorAll('.mais').forEach((b) => {
      b.addEventListener('click', () => adicionar(+b.dataset.id));
    });
  }

  function renderCabecalho() {
    cab.innerHTML =
      colunas
        .map((c, i) => `<th scope="col"><button data-i="${i}">${c}<span class="seta" aria-hidden="true"></span></button></th>`)
        .join('') + '<th class="acao" scope="col"></th>';
    cab.querySelectorAll('button').forEach((b) => {
      b.addEventListener('click', () => {
        const i = +b.dataset.i;
        if (ordem.col === i) ordem.asc = !ordem.asc;
        else { ordem.col = i; ordem.asc = i === 0; }
        cab.querySelectorAll('button').forEach((x) => x.classList.remove('asc', 'desc'));
        b.classList.add(ordem.asc ? 'asc' : 'desc');
        render();
      });
    });
  }

  /* ---------- Refeição ---------- */

  function adicionar(id) {
    const existente = refeicao.find((r) => r.id === id);
    if (existente) existente.gramas += 100;
    else refeicao.push({ id, gramas: 100 });
    renderRefeicao();
    document.getElementById('refeicao').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function renderRefeicao() {
    const tem = refeicao.length > 0;
    refVazia.hidden = tem;
    refTotais.hidden = !tem;
    refLimpar.hidden = !tem;

    refLista.innerHTML = refeicao
      .map((r) => {
        const l = linhas[r.id];
        const kcal = numero(l.v[1]) * r.gramas / 100;
        return `<div class="ref-item">
          <span class="ref-nome">${l.v[0]}</span>
          <span class="ref-qtd"><input type="number" min="1" max="5000" step="5" value="${r.gramas}" data-id="${r.id}" aria-label="Gramas de ${l.v[0]}" /> g</span>
          <span class="ref-kcal">${fmt(kcal)} kcal</span>
          <button class="ref-rem" data-id="${r.id}" aria-label="Remover ${l.v[0]}">×</button>
        </div>`;
      })
      .join('');

    // Totais para todas as colunas numéricas
    if (tem) {
      const totais = colunas.slice(1).map((_, ci) =>
        refeicao.reduce((soma, r) => soma + numero(linhas[r.id].v[ci + 1]) * r.gramas / 100, 0)
      );
      const gramasTotal = refeicao.reduce((s, r) => s + r.gramas, 0);
      refTotais.innerHTML =
        `<span class="tot-label">Totais (${fmt(gramasTotal)} g):</span>` +
        totais
          .map((v, i) => `<span class="tot"><span class="tot-n">${fmt(v)}</span> ${colunas[i + 1].replace(/\s*\(100g\)/i, '')}</span>`)
          .join('');
    }

    refLista.querySelectorAll('input').forEach((inp) => {
      inp.addEventListener('change', () => {
        const item = refeicao.find((r) => r.id === +inp.dataset.id);
        if (item) item.gramas = Math.max(1, +inp.value || 100);
        renderRefeicao();
      });
    });
    refLista.querySelectorAll('.ref-rem').forEach((b) => {
      b.addEventListener('click', () => {
        refeicao = refeicao.filter((r) => r.id !== +b.dataset.id);
        renderRefeicao();
      });
    });
  }

  refLimpar.addEventListener('click', () => { refeicao = []; renderRefeicao(); });

  fetch('/data/alimentos.csv')
    .then((r) => { if (!r.ok) throw new Error(); return r.text(); })
    .then((txt) => { parseCSV(txt); renderCabecalho(); render(); })
    .catch(() => { document.getElementById('erro').hidden = false; });

  q.addEventListener('input', render);
</script>

<style>
  .lead { color: var(--muted); max-width: 560px; margin-top: 14px; }
  .lead strong { color: var(--amber); font-weight: 500; }

  /* Painel da refeição */
  .refeicao {
    border: 1px solid var(--line-strong);
    background: var(--panel);
    padding: 20px 22px;
    margin-bottom: 28px;
  }
  .vazia { font-size: 14px; color: var(--faint); margin: 0; }
  .mais-ex {
    display: inline-block;
    border: 1px solid var(--amber);
    color: var(--amber);
    width: 20px;
    height: 20px;
    line-height: 18px;
    text-align: center;
    font-size: 14px;
  }
  .ref-lista { display: grid; gap: 8px; }
  .ref-item {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    padding: 8px 0;
    border-bottom: 1px solid var(--line);
    font-size: 14px;
  }
  .ref-nome { flex: 1; min-width: 160px; color: var(--paper); }
  .ref-qtd { color: var(--faint); white-space: nowrap; }
  .ref-qtd input {
    width: 74px;
    background: transparent;
    border: 1px solid var(--line-strong);
    color: var(--paper);
    font-family: var(--font-display);
    font-size: 15px;
    padding: 5px 8px;
    text-align: right;
  }
  .ref-qtd input:focus { outline: 2px solid var(--amber); outline-offset: 2px; }
  .ref-kcal {
    font-family: var(--font-display);
    font-size: 13px;
    color: var(--muted);
    white-space: nowrap;
  }
  .ref-rem {
    background: none;
    border: 1px solid var(--line-strong);
    color: var(--faint);
    width: 26px;
    height: 26px;
    cursor: pointer;
    font-size: 15px;
    line-height: 1;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .ref-rem:hover { border-color: var(--blood); color: var(--blood); }
  .ref-totais {
    display: flex;
    align-items: baseline;
    gap: 8px 18px;
    flex-wrap: wrap;
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--amber);
  }
  .tot-label {
    font-family: var(--font-display);
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--faint);
  }
  .tot { font-size: 13px; color: var(--muted); white-space: nowrap; }
  .tot-n {
    font-family: var(--font-display);
    font-size: 20px;
    color: var(--amber);
  }
  .limpar { margin-top: 16px; padding: 8px 16px; font-size: 12px; }

  /* Tabela */
  .toolbar { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
  input[type='search'] {
    flex: 1;
    min-width: 220px;
    background: transparent;
    border: 1px solid var(--line-strong);
    color: var(--paper);
    font-family: var(--font-body);
    font-size: 15px;
    padding: 11px 16px;
  }
  input[type='search']::placeholder { color: var(--faint); }
  input[type='search']:focus { outline: 2px solid var(--amber); outline-offset: 2px; }
  .count {
    font-family: var(--font-display);
    font-size: 12px;
    letter-spacing: 2px;
    color: var(--faint);
    margin: 16px 0;
  }
  .table-wrap { overflow-x: auto; border: 1px solid var(--line-strong); }
  table { width: 100%; border-collapse: collapse; min-width: 620px; }
  th { text-align: left; border-bottom: 1px solid var(--line-strong); background: var(--panel); }
  th button {
    width: 100%;
    background: none;
    border: none;
    color: var(--faint);
    font-family: var(--font-display);
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 12px 14px;
    text-align: left;
    cursor: pointer;
  }
  th button:hover { color: var(--amber); }
  th button.asc .seta::after { content: ' ↑'; color: var(--amber); }
  th button.desc .seta::after { content: ' ↓'; color: var(--amber); }
  td { padding: 10px 14px; border-bottom: 1px solid var(--line); font-size: 14px; }
  td.nome { color: var(--paper); }
  td.num { color: var(--muted); font-variant-numeric: tabular-nums; }
  td.acao, th.acao { width: 46px; padding: 6px 10px; }
  .mais {
    background: transparent;
    border: 1px solid var(--amber);
    color: var(--amber);
    width: 28px;
    height: 28px;
    font-size: 17px;
    line-height: 1;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .mais:hover { background: var(--amber); color: var(--amber-ink); }
  tr:hover td { background: var(--panel); }
  .nota { margin-top: 16px; color: var(--blood); font-size: 14px; }
  .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); }
</style>
