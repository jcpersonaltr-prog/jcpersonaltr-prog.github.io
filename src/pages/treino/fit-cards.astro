---
import Base from '../../layouts/Base.astro';
import textos from '../../data/textos.json';
import dados from '../../data/fitcards.json';
const t = textos.fitcards;
const cards = dados.cards;

const categorias = ['Todas', ...new Set(cards.map((c) => c.categoria))];
const niveis = ['Todos', 'Iniciante', 'Intermédio', 'Avançado'];
---

<Base title="Fit Cards" description="Cartões de treino do Método Perfektus, filtráveis por categoria e nível.">
  <section class="section grain">
    <div class="wrap">
      <p class="stamp">02 — Treino / Fit Cards</p>
      <h1>{t.titulo}</h1>
      <p class="lead">{t.lead}</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="filters" id="filtros">
        <div class="filter-row" role="group" aria-label="Filtrar por categoria">
          <span class="filter-label">Categoria</span>
          {categorias.map((c, i) => (
            <button class:list={['pillbtn', { on: i === 0 }]} data-filter="categoria" data-value={c}>{c}</button>
          ))}
        </div>
        <div class="filter-row" role="group" aria-label="Filtrar por nível">
          <span class="filter-label">Nível</span>
          {niveis.map((n, i) => (
            <button class:list={['pillbtn', { on: i === 0 }]} data-filter="nivel" data-value={n}>{n}</button>
          ))}
        </div>
      </div>

      <p class="count" id="count" aria-live="polite"></p>

      <div class="grid" id="grelha">
        {cards.map((c) => (
          <article class="card fitcard" data-categoria={c.categoria} data-nivel={c.nivel}>
            <header>
              <h3>{c.titulo}</h3>
              <span class="meta">
                <span class="pill pill--amber">{c.categoria}</span>
                <span class="pill">{c.nivel}</span>
                <span class="pill">{c.tempo}</span>
              </span>
            </header>
            <p class="equip">{c.equipamento}</p>
            <ul>
              {c.exercicios.map((e) => (
                <li><span class="ex">{e.nome}</span><span class="dose">{e.dose}</span></li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>

<script>
  const estado = { categoria: 'Todas', nivel: 'Todos' };
  const botoes = document.querySelectorAll('.pillbtn');
  const cartas = document.querySelectorAll('.fitcard');
  const count = document.getElementById('count');

  function aplicar() {
    let visiveis = 0;
    cartas.forEach((c) => {
      const okCat = estado.categoria === 'Todas' || c.dataset.categoria === estado.categoria;
      const okNiv = estado.nivel === 'Todos' || c.dataset.nivel === estado.nivel;
      const mostra = okCat && okNiv;
      c.style.display = mostra ? '' : 'none';
      if (mostra) visiveis++;
    });
    count.textContent = visiveis === 1 ? '1 cartão' : `${visiveis} cartões`;
  }

  botoes.forEach((b) => {
    b.addEventListener('click', () => {
      const tipo = b.dataset.filter;
      estado[tipo] = b.dataset.value;
      document
        .querySelectorAll(`.pillbtn[data-filter="${tipo}"]`)
        .forEach((x) => x.classList.toggle('on', x === b));
      aplicar();
    });
  });

  aplicar();
</script>

<style>
  .lead { color: var(--muted); max-width: 560px; margin-top: 14px; }
  .filters { display: grid; gap: 12px; margin-bottom: 8px; }
  .filter-row { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
  .filter-label {
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--faint);
    min-width: 88px;
  }
  .pillbtn {
    background: transparent;
    border: 1px solid var(--line-strong);
    color: var(--muted);
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 1px;
    padding: 5px 14px;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .pillbtn:hover { border-color: var(--amber); color: var(--paper); }
  .pillbtn.on { border-color: var(--amber); color: var(--amber); }
  .count {
    font-family: var(--font-display);
    font-size: 12px;
    letter-spacing: 2px;
    color: var(--faint);
    margin: 18px 0;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 14px;
  }
  .fitcard header { margin-bottom: 12px; }
  .fitcard h3 { margin-bottom: 8px; }
  .meta { display: flex; gap: 6px; flex-wrap: wrap; }
  .pill {
    border: 1px solid var(--line-strong);
    color: var(--muted);
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 2px 10px;
  }
  .pill--amber { border-color: var(--amber); color: var(--amber); }
  .equip {
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--faint);
    margin: 0 0 12px;
  }
  ul { list-style: none; margin: 0; padding: 0; }
  li {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 8px 0;
    border-top: 1px solid var(--line);
    font-size: 14px;
  }
  .ex { color: var(--paper); }
  .dose { color: var(--amber); font-family: var(--font-display); font-size: 13px; white-space: nowrap; }
</style>
