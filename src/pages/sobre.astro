---
import Base from '../layouts/Base.astro';
import dados from '../data/sobre.json';

// Página gerida no painel /admin (Páginas → Sobre).
// A biografia aceita parágrafos (linha em branco entre eles) e **negrito**.
function paraHtml(texto: string): string {
  return texto
    .split(/\n\s*\n/)
    .map((p) => `<p>${p.trim().replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')}</p>`)
    .join('');
}
const biografiaHtml = paraHtml(dados.biografia);
---

<Base title="Sobre" description="João Carvalho — personal trainer, fundador do Método Perfektus e autor do The Plasmik Report.">
  <section class="section grain">
    <div class="wrap">
      <p class="stamp">06 — Sobre</p>
      <h1>{dados.titulo}</h1>
    </div>
  </section>
  <section class="section">
    <div class="wrap cols">
      <div class="prose" set:html={biografiaHtml} />
      <aside>
        {dados.cartoes.map((c) => (
          <div class="card">
            <span class="card-title">{c.titulo}</span>
            <p>{c.texto}</p>
          </div>
        ))}
      </aside>
    </div>
  </section>
</Base>

<style>
  .cols {
    display: grid;
    grid-template-columns: 1.4fr 0.8fr;
    gap: clamp(24px, 4vw, 48px);
    align-items: start;
  }
  aside { display: grid; gap: 14px; }
  @media (max-width: 720px) { .cols { grid-template-columns: 1fr; } }
</style>
