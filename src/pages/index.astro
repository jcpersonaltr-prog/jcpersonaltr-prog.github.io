---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import dados from '../data/home.json';

// Textos geridos no painel /admin (Páginas → Homepage).
const edicoes = (await getCollection('relatorio')).sort((a, b) => b.data.numero - a.data.numero);
const ultima = edicoes[0];
const mes = ultima.data.data
  .toLocaleDateString('pt-PT', { month: 'short', year: '2-digit' })
  .replace('.', '')
  .toUpperCase();

const tituloLinhas = dados.titulo.split('\n');
---

<Base title="Início">
  <section class="hero grain">
    <div class="wrap hero-grid">
      <div>
        <p class="stamp">{dados.kicker}</p>
        <h1>{tituloLinhas.map((l, i) => (<>{i > 0 && <br />}{l}</>))}</h1>
        <p class="lead">{dados.lead}</p>
        <div class="actions">
          <a class="btn btn--amber" href={`/relatorio/${ultima.id}/`}>{dados.botaoEdicao}</a>
          <a class="btn btn--ghost" href="/comunidade/">{dados.botaoComunidade}</a>
        </div>
      </div>
      <figure class="hero-photo">
        <img
          src={encodeURI(dados.foto || "/images/hero.jpg")}
          alt={dados.fotoAlt}
          class="bw"
          width="640"
          height="800"
          loading="eager"
          style={`object-position: ${dados.fotoEnquadramento};`}
        />
        <figcaption>{dados.fotoLegenda}</figcaption>
      </figure>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <p class="stamp stamp--faint">Última edição — Nº {ultima.data.numero}</p>
      <a class="card featured" href={`/relatorio/${ultima.id}/`}>
        <span class="date-badge">
          <span class="n">{String(ultima.data.data.getDate()).padStart(2, '0')}</span>
          <span class="d">{mes}</span>
        </span>
        <span class="featured-body">
          <h3>{ultima.data.titulo}</h3>
          <p>{ultima.data.resumo}</p>
          <span class="readlink">Ler a edição →</span>
        </span>
      </a>
    </div>
  </section>

  <section class="section">
    <div class="wrap grid-3">
      {dados.seccoes.map((s) => (
        <a class="card" href={s.href}>
          <span class="num">{s.num}</span>
          <span class="card-title">{s.titulo}</span>
          <p>{s.desc}</p>
        </a>
      ))}
    </div>
  </section>
</Base>

<script>
  // Modo de alinhamento da foto do hero: abre a homepage com ?ajustar
  // no fim do endereço, arrasta a foto até gostares do enquadramento,
  // e copia o valor para o painel (Páginas → Homepage → Enquadramento).
  if (new URLSearchParams(location.search).has('ajustar')) {
    const img = document.querySelector('.hero-photo img');
    if (img) {
      const overlay = document.createElement('div');
      overlay.id = 'ajuste-overlay';
      overlay.innerHTML = `<span>Arrasta a foto para alinhar</span><code id="ajuste-valor"></code><button id="ajuste-copiar" type="button">Copiar</button>`;
      document.querySelector('.hero-photo').appendChild(overlay);
      const valorEl = overlay.querySelector('#ajuste-valor');
      const copiarBt = overlay.querySelector('#ajuste-copiar');

      let pos = (getComputedStyle(img).objectPosition || '50% 50%')
        .split(' ')
        .map((v) => parseFloat(v));
      if (pos.length < 2 || pos.some(isNaN)) pos = [50, 50];

      const mostrar = () => {
        const txt = `${Math.round(pos[0])}% ${Math.round(pos[1])}%`;
        img.style.objectPosition = txt;
        valorEl.textContent = txt;
      };
      mostrar();

      let ativo = false, px = 0, py = 0;
      img.style.cursor = 'grab';
      img.style.touchAction = 'none';
      img.addEventListener('pointerdown', (e) => {
        ativo = true; px = e.clientX; py = e.clientY;
        img.setPointerCapture(e.pointerId);
        img.style.cursor = 'grabbing';
        e.preventDefault();
      });
      img.addEventListener('pointermove', (e) => {
        if (!ativo) return;
        const r = img.getBoundingClientRect();
        pos[0] = Math.min(100, Math.max(0, pos[0] - ((e.clientX - px) / r.width) * 100));
        pos[1] = Math.min(100, Math.max(0, pos[1] - ((e.clientY - py) / r.height) * 100));
        px = e.clientX; py = e.clientY;
        mostrar();
      });
      img.addEventListener('pointerup', () => { ativo = false; img.style.cursor = 'grab'; });

      copiarBt.addEventListener('click', () => {
        navigator.clipboard.writeText(valorEl.textContent).then(() => {
          copiarBt.textContent = 'Copiado ✓';
          setTimeout(() => (copiarBt.textContent = 'Copiar'), 1800);
        });
      });
    }
  }
</script>

<style>
  .hero {
    border-bottom: 1px solid var(--line);
    padding: clamp(40px, 7vw, 80px) 0;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: clamp(24px, 5vw, 56px);
    align-items: center;
  }
  .lead {
    font-size: 16px;
    color: var(--muted);
    max-width: 480px;
    margin: 18px 0 0;
  }
  .actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 28px; }
  .hero-photo { margin: 0; border: 1px solid var(--line-strong); padding: 10px; }
  #ajuste-overlay {
    position: absolute;
    left: 10px;
    right: 10px;
    bottom: 34px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    background: rgba(10, 10, 10, 0.92);
    border: 1px solid var(--amber);
    padding: 8px 12px;
    font-size: 12px;
    color: var(--muted);
    z-index: 5;
  }
  #ajuste-overlay code {
    font-family: var(--font-display);
    font-size: 15px;
    color: var(--amber);
  }
  #ajuste-overlay button {
    background: var(--amber);
    color: var(--amber-ink);
    border: none;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 5px 12px;
    cursor: pointer;
  }
  .hero-photo { position: relative; }

  .hero-photo img { aspect-ratio: 4 / 5; object-fit: cover; }
  .hero-photo figcaption {
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--faint);
    margin-top: 8px;
    text-align: right;
  }
  .featured { display: flex; gap: 20px; align-items: flex-start; }
  .featured-body { flex: 1; min-width: 220px; }
  .featured h3 { margin-bottom: 8px; }
  .featured p { font-size: 14px; color: var(--muted); margin: 0 0 12px; }
  .readlink {
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--amber);
  }
  .grid-3 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
  }
  @media (max-width: 720px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-photo { max-width: 380px; }
    .featured { flex-direction: column; }
  }
</style>
