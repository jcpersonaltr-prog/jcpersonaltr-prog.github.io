---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import dados from '../data/home.json';

// Textos geridos no painel /admin (Páginas → Homepage).
const edicoes = (await getCollection('relatorio')).sort((a, b) => b.data.numero - a.data.numero);
const ultima = edicoes[0];
const mes = ultima.data.data
  .toLocaleDateString('pt-PT', { month: 'short', year: '2-digit' })
  .replace('.', '')
  .toUpperCase();

const tituloLinhas = dados.titulo.split('\n');
---

<Base title="Início">
  <section class="hero grain">
    <div class="wrap hero-grid">
      <div>
        <p class="stamp">{dados.kicker}</p>
        <h1>{tituloLinhas.map((l, i) => (<>{i > 0 && <br />}{l}</>))}</h1>
        <p class="lead">{dados.lead}</p>
        <div class="actions">
          <a class="btn btn--amber" href={`/relatorio/${ultima.id}/`}>{dados.botaoEdicao}</a>
          <a class="btn btn--ghost" href="/comunidade/">{dados.botaoComunidade}</a>
        </div>
      </div>
      <figure class="hero-photo">
        <img
          src="/images/hero.jpg"
          alt={dados.fotoAlt}
          class="bw"
          width="640"
          height="800"
          loading="eager"
          style={`object-position: ${dados.fotoEnquadramento};`}
        />
        <figcaption>{dados.fotoLegenda}</figcaption>
      </figure>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <p class="stamp stamp--faint">Última edição — Nº {ultima.data.numero}</p>
      <a class="card featured" href={`/relatorio/${ultima.id}/`}>
        <span class="date-badge">
          <span class="n">{String(ultima.data.data.getDate()).padStart(2, '0')}</span>
          <span class="d">{mes}</span>
        </span>
        <span class="featured-body">
          <h3>{ultima.data.titulo}</h3>
          <p>{ultima.data.resumo}</p>
          <span class="readlink">Ler a edição →</span>
        </span>
      </a>
    </div>
  </section>

  <section class="section">
    <div class="wrap grid-3">
      {dados.seccoes.map((s) => (
        <a class="card" href={s.href}>
          <span class="num">{s.num}</span>
          <span class="card-title">{s.titulo}</span>
          <p>{s.desc}</p>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  .hero {
    border-bottom: 1px solid var(--line);
    padding: clamp(40px, 7vw, 80px) 0;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: clamp(24px, 5vw, 56px);
    align-items: center;
  }
  .lead {
    font-size: 16px;
    color: var(--muted);
    max-width: 480px;
    margin: 18px 0 0;
  }
  .actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 28px; }
  .hero-photo { margin: 0; border: 1px solid var(--line-strong); padding: 10px; }
  .hero-photo img { aspect-ratio: 4 / 5; object-fit: cover; }
  .hero-photo figcaption {
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--faint);
    margin-top: 8px;
    text-align: right;
  }
  .featured { display: flex; gap: 20px; align-items: flex-start; }
  .featured-body { flex: 1; min-width: 220px; }
  .featured h3 { margin-bottom: 8px; }
  .featured p { font-size: 14px; color: var(--muted); margin: 0 0 12px; }
  .readlink {
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--amber);
  }
  .grid-3 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
  }
  @media (max-width: 720px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-photo { max-width: 380px; }
    .featured { flex-direction: column; }
  }
</style>
