---
import Base from '../layouts/Base.astro';
import cabecalhos from '../data/textos.json';
import { getCollection } from 'astro:content';
const t = cabecalhos.tinta;

const textos = (await getCollection('tinta')).sort(
  (a, b) => b.data.data.valueOf() - a.data.data.valueOf()
);

const rotulos: Record<string, string> = {
  reflexao: 'Reflexão',
  leafs: 'Leafs From a Dead Tree',
  principio: 'Princípio',
};
const tipos = ['Todos', ...new Set(textos.map((t) => t.data.tipo))];

const fmt = (d: Date) =>
  d.toLocaleDateString('pt-PT', { day: '2-digit', month: 'short', year: 'numeric' }).replace('.', '');
---

<Base title="Tinta" description="Reflexões, Leafs From a Dead Tree e os princípios do The Plasmik Report — a escrita por trás do treino.">
  <section class="section grain">
    <div class="wrap">
      <p class="stamp">04 — Tinta</p>
      <h1>{t.titulo}</h1>
      <p class="lead">{t.lead}</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="filter-row" role="group" aria-label="Filtrar textos">
        {tipos.map((t, i) => (
          <button class:list={['pillbtn', { on: i === 0 }]} data-value={t}>
            {t === 'Todos' ? 'Todos' : rotulos[t]}
          </button>
        ))}
      </div>

      <div class="lista">
        {textos.map((t) => (
          <a class="card texto" href={`/tinta/${t.id}/`} data-tipo={t.data.tipo}>
            <span class="meta">
              <span class="pill">{rotulos[t.data.tipo]}</span>
              <span class="data">{fmt(t.data.data)}</span>
            </span>
            <h3>{t.data.titulo}</h3>
            {t.data.resumo && <p>{t.data.resumo}</p>}
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<script>
  const botoes = document.querySelectorAll('.pillbtn');
  const itens = document.querySelectorAll('.texto');
  botoes.forEach((b) => {
    b.addEventListener('click', () => {
      botoes.forEach((x) => x.classList.toggle('on', x === b));
      const v = b.dataset.value;
      itens.forEach((i) => {
        i.style.display = v === 'Todos' || i.dataset.tipo === v ? '' : 'none';
      });
    });
  });
</script>

<style>
  .lead { color: var(--muted); max-width: 520px; margin-top: 14px; }
  .filter-row { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 22px; }
  .pillbtn {
    background: transparent;
    border: 1px solid var(--line-strong);
    color: var(--muted);
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 1px;
    padding: 5px 14px;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .pillbtn:hover { border-color: var(--amber); color: var(--paper); }
  .pillbtn.on { border-color: var(--amber); color: var(--amber); }
  .lista { display: grid; gap: 14px; max-width: 720px; }
  .meta { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
  .pill {
    border: 1px solid var(--amber);
    color: var(--amber);
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 2px 10px;
  }
  .data {
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--faint);
  }
  .texto h3 { margin-bottom: 6px; }
  .texto p { font-size: 14px; color: var(--muted); margin: 0; }
</style>
