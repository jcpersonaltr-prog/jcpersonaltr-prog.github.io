---
import Base from '../layouts/Base.astro';
import dados from '../data/comunidade.json';

// Textos e link do WhatsApp geridos no painel /admin (Páginas → Comunidade).
const tituloLinhas = dados.titulo.split('\n');
---

<Base title="Comunidade" description="A comunidade do The Plasmik Report: treino, nutrição e pensamento crítico, sem ruído e sem poses.">
  <section class="section grain">
    <div class="wrap">
      <p class="stamp">05 — Comunidade</p>
      <h1>{tituloLinhas.map((l, i) => (<>{i > 0 && <br />}{l}</>))}</h1>
      <p class="lead">{dados.lead}</p>
      <a class="btn btn--amber" href={dados.whatsappLink} target="_blank" rel="noopener">{dados.botao}</a>
    </div>
  </section>
  <section class="section">
    <div class="wrap">
      <p class="stamp stamp--faint">{dados.regrasTitulo}</p>
      <ol class="rules">
        {dados.regras.map((r) => (
          <li><strong>{r.titulo}</strong> {r.texto}</li>
        ))}
      </ol>
    </div>
  </section>
</Base>

<style>
  .lead { color: var(--muted); max-width: 540px; margin: 16px 0 28px; }
  .rules {
    list-style: none;
    counter-reset: rule;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 14px;
    max-width: 640px;
  }
  .rules li {
    counter-increment: rule;
    border: 1px solid var(--line-strong);
    background: var(--panel);
    padding: 18px 20px 18px 64px;
    position: relative;
    font-size: 15px;
    color: var(--muted);
  }
  .rules li::before {
    content: '0' counter(rule);
    position: absolute;
    left: 20px;
    top: 16px;
    font-family: var(--font-display);
    font-size: 20px;
    color: var(--amber);
  }
  .rules strong { color: var(--paper); font-weight: 500; }
</style>
